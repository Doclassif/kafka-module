{
    "name": "doclassif/laravel-outbox-kafka",
    "type": "laravel-module",
    "description": "Outbox pattern for Kafka as a Laravel module",
    "require": {
        "php": "^8.0",
        "joshbrw/laravel-module-installer": "^2.0"
    },
    "extra": {
        "laravel": {
            "providers": [],
            "aliases": {}
        },    
        "module-dir": "modules"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Kafka\\": "app/",
            "Modules\\Kafka\\Database\\Factories\\": "database/factories/",
            "Modules\\Kafka\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Feature\\Modules\\Kafka\\": "tests/Feature/",
            "Tests\\Unit\\Modules\\Kafka\\": "tests/Unit/"
        }
    }
}
